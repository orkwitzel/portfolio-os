{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "compatibility_date": "2026-05-19",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "orkwitzel.com",
      "custom_domain": true
    },
    {
      "pattern": "www.orkwitzel.com",
      "custom_domain": true
    }
  ]
}
